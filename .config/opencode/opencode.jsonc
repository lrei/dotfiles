{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "**": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 60000,
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@slkiser/opencode-quota"
  ],
  "mcp": {
    "tavily-remote-mcp": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={file:~/.config/.secrets/tavily}",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true,
      "headers": {
        "x-api-key": "{file:~/.config/.secrets/exa}"
      }
    },
    "paperlantern": {
      "type": "remote",
      "url": "https://mcp.paperlantern.ai/chat/mcp?key={file:~/.config/.secrets/paperlantern}",
      "enabled": true
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/sse?Authorization={file:~/.config/.secrets/zai}",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep-app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa",
      "enabled": true
    }
  },
}
